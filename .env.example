# Copy this file to .env and fill in your values. NEVER commit .env.

# --- OpenAI ---
OPENAI_API_KEY=sk-your-key-here

# --- Anthropic / Claude ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_ENABLE_THINKING=false
ANTHROPIC_EFFORT=medium
ANTHROPIC_TOP_P=0.98
ANTHROPIC_MAX_TOOL_CALLS=6
ANTHROPIC_MAX_PAUSE_TURNS=8
ANTHROPIC_WEB_SEARCH_COUNTRY=DE
ANTHROPIC_WEB_SEARCH_TIMEZONE=Europe/Berlin
# ANTHROPIC_WEB_SEARCH_CITY=Berlin

# --- PostgreSQL ---
PGPASSWORD=your_postgres_password
PGUSER=postgres
PGHOST=localhost
PGDATABASE=digital_ai_index_db
PGPORT=5432

# --- Optional run tuning (defaults shown) ---
REPEAT_COUNT=5
SESSION_DELAY_MS=750
REQUEST_TIMEOUT_MS=300000
MAX_API_RETRIES=4
RETRY_BASE_DELAY_MS=2000
TOP_P=0.98
WEB_SEARCH_CONTEXT_SIZE=medium
MAX_TOOL_CALLS=6
REASONING_EFFORT=low
TEXT_VERBOSITY=medium
WEB_SEARCH_COUNTRY=DE
WEB_SEARCH_TIMEZONE=Europe/Berlin
# RUN_NOTES=Short free-text observation saved on session_runs
# PROFILE_ID=1          # batch: run only this one profile
# PROMPT_LIMIT=0        # explorer: run only first N prompts (0 = all)
